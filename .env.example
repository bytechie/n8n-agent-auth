# ========================================
# n8n Agent Auth - Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# ========================================
# Descope Configuration
# ========================================
# Your Descope Project ID from the console
DESCOPE_PROJECT_ID=your_descope_project_id_here

# ========================================
# n8n Configuration
# ========================================
# Your n8n instance URL (for local development)
N8N_BASE_URL=http://n8n:5678

# The webhook URL path for the specific workflow
# Example: /webhook/my-secure-workflow
N8N_WEBHOOK_PATH=/webhook/your-workflow-name

# Full webhook URL (for production, override N8N_BASE_URL + N8N_WEBHOOK_PATH)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-workflow-name

# Secret API key for n8n webhook authentication
# Generate a strong random string (e.g., openssl rand -base64 32)
N8N_API_KEY=your_n8n_api_key_here

# ========================================
# Gateway Configuration
# ========================================
# Port for the MCP gateway server
PORT=3000

# Node environment
NODE_ENV=development

# ========================================
# Optional: Claude Desktop Configuration
# ========================================
# The public URL where this gateway will be accessible
# Used for generating Claude Desktop config
GATEWAY_PUBLIC_URL=http://localhost:3000

# Descope Access Key for Claude Desktop (generate in Descope console)
DESCOPE_AGENT_ACCESS_KEY=your_descope_access_key_here
